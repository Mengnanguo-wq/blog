<div class="main-right">
  <div class="main-right--board">
    <div class="main-right--title">
      <h5>公告栏</h5>
      <i class="iconfont icon-gonggao"></i>
    </div>
    <div class="main-right--content">
      <%- theme.notice %> 
    </div>
  </div>

  <div id="aplayer" class="main-right--music"></div>

  <div class="operate-items">
    <div class="operate-item backtop">
      <i class="iconfont icon-huidaodingbu"></i>
      <span>回到顶部</span>
    </div>
    <% if (theme.comments.enable) { %>
    <div class="operate-item turn-comment hidden">
      <i class="iconfont icon-pinglun"></i>
      <span>查看评论</span>
    </div>
    <% } %>
  </div>

  <div class="main-right--site">
    <div class="main-right--power">
      <p>Power By <a href="https://hexo.io/zh-cn/docs/">Hexo</a>.</p>
      <p>Theme：<a href="https://github.com/Aizener/hexo-theme-cola">Cola.</a></p>
    </div>
    <p class="main-right--refer"><a href="https://beian.miit.gov.cn/#/Integrated/index"><%- theme.copyright %></a> </p>
  </div>
</div>
<script>
  function setOperateItem () {
    const reg = /\d{4}\/\d{2}\/\d{2}\/.+/
    const path = location.pathname
    const operateDom = document.querySelector('.main-right .operate-items')
    const commentDom = document.querySelector('.turn-comment')
    const cateloguDom = document.querySelector('.article-catelogue > .article-catelogue--wrapper');

    if (commentDom) {
      if (reg.test(path) || path.match(/\/log\/.+/)) {
        commentDom.classList.remove('hidden')
        const newDom = operateDom.cloneNode(true);
        const _backtopDom = newDom.querySelector('.backtop');
        const _commentDom = newDom.querySelector('.turn-comment');
        _backtopDom.addEventListener('click', () => backTopEvent());
        _commentDom.addEventListener('click', () => commentDomEvent());
        cateloguDom.appendChild(newDom);
      } else {
        commentDom.classList.add('hidden')
      }
    }
  }

  setOperateItem()

  // ===== 音乐播放器 =====
  // 优先使用网易云歌单（通过 Meting API 获取），后备使用静态配置的 musics
  <%
    const neteaseId = theme.netease_playlist_id || ''
    const hasStaticMusics = theme.musics && theme.musics.length > 0
  %>

  const neteaseId = '<%= neteaseId %>'

  if (neteaseId) {
    // 网易云音乐模式：通过 Meting API 获取歌单
    const metingApi = 'https://api.injahow.cn/meting/'
    const url = metingApi + '?server=netease&type=playlist&id=' + neteaseId

    // 显示加载状态
    const playerEl = document.querySelector('#aplayer')
    playerEl.innerHTML = '<div style="padding:20px;text-align:center;color:#999;font-size:13px">🎵 加载歌单中...</div>'

    fetch(url)
      .then(res => res.json())
      .then(data => {
        if (!data || !data.length) throw new Error('歌单为空')
        new APlayer({
          container: playerEl,
          audio: data.map(song => ({
            name: song.name,
            artist: song.artist,
            url: song.url,
            cover: song.pic,
            lrc: song.lrc
          })),
          autoplay: false,
        })
      })
      .catch(err => {
        console.error('🎵 网易云加载失败:', err)
        playerEl.innerHTML = '<div style="padding:20px;text-align:center;color:#999;font-size:13px">🎵 音乐加载失败，<a style="color:#666;text-decoration:underline;cursor:pointer" onclick="location.reload()">点击重试</a></div>'
      })
  }
  <% if (hasStaticMusics) { %>
  else {
    // 静态音乐模式：使用配置中的 musics 列表
    const staticMusics = <%- JSON.stringify(theme.musics.map(function(m) { return {name: m[0], artist: m[1], url: m[2], cover: m[3]} })) %>
    new APlayer({
      container: document.querySelector('#aplayer'),
      audio: staticMusics,
      autoplay: false,
    })
  }
  <% } %>

  $(document).on('pjax:complete', function() {
    setOperateItem()
  })

  document.querySelector('.backtop').addEventListener('click', () => {
    backTopEvent();
  })
  const dom = document.querySelector('.turn-comment')
  dom && dom.addEventListener('click', () => {
    commentDomEvent();
  })

  function backTopEvent() {
    document.documentElement.scrollTo({
      top: 0,
      behavior: 'smooth'
    })
  }

  function commentDomEvent() {
    const commentDom = document.querySelector('.comments-intro')
    if (!commentDom) return
    const top = commentDom.offsetTop, height = commentDom.offsetHeight
    document.documentElement.scrollTo({
      top: top - 2 * height,
      behavior: 'smooth'
    })
  }
</script>